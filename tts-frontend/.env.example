# Backend origin. In production, point this at your deployed API.
VITE_BACKEND_URL=http://localhost:5000

# Supabase project settings -> API. The anon key is safe to ship in the browser
# bundle; it only grants what your RLS policies allow.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
