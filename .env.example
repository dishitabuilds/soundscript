# Supabase project settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ElevenLabs -> Profile -> API key. This one is a real secret: it is never sent
# to the browser, and anyone holding it can spend your credits.
ELEVEN_API_KEY=your-elevenlabs-key

# Comma-separated origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:5173

# Characters a single user may synthesise per rolling 24h.
DAILY_CHAR_QUOTA=10000
