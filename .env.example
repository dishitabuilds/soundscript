# Supabase project settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Service role key (Supabase settings -> API). Bypasses RLS, so it is optional
# on purpose: only the standalone worker (npm run worker), the podcast feed,
# and email notifications need it. Leave unset to run without those.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ElevenLabs -> Profile -> API key. This one is a real secret: it is never sent
# to the browser, and anyone holding it can spend your credits.
ELEVEN_API_KEY=your-elevenlabs-key

# Optional second TTS provider. With a key set, OpenAI voices appear in the
# voice picker alongside ElevenLabs.
# OPENAI_API_KEY=your-openai-key

# Which provider narrates when a document does not choose: elevenlabs | openai
TTS_PROVIDER=elevenlabs

# Optional: "your audiobook is ready" emails, sent by the standalone worker
# for jobs that finish after the user left. https://resend.com API key.
# RESEND_API_KEY=your-resend-key
# NOTIFY_FROM_EMAIL="SoundScript <you@yourdomain.com>"

# Comma-separated origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:5173

# Characters a single user may synthesise per rolling 24h.
DAILY_CHAR_QUOTA=10000

# Set to false when the standalone worker owns the queue: the API then only
# inserts queued jobs and `npm run worker` (with the service role key) claims
# them. Default true = synthesis runs inside the API process.
INLINE_PROCESSING=true
